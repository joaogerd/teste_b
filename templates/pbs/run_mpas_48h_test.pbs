#!/bin/bash
#PBS -N mpas_48h_x1.10242
#PBS -q pesqmini
#PBS -l select=1:ncpus=64:mpiprocs=64
#PBS -l walltime=00:30:00
#PBS -j oe

set -euo pipefail

PROJECT_ROOT=/p/projetos/monan_das/joao.gerd/projects/mpas-bmatrix-global
RUN_DIR=/p/projetos/monan_das/joao.gerd/work/mpas-bmatrix-global/runs/test48h_x1.10242_2018041421_np64

source "${PROJECT_ROOT}/scripts/load_jaci_env.sh"

cd "${RUN_DIR}"

export OMP_NUM_THREADS=1
export FI_CXI_RX_MATCH_MODE=hybrid
ulimit -s unlimited || true

echo "Job started at $(date -Is)"
echo "Host: $(hostname)"
echo "PBS_JOBID=${PBS_JOBID:-unknown}"
echo "RUN_DIR=${RUN_DIR}"
echo

module list || true

echo
echo "Running MPAS 48h test..."
mpiexec -n 64 ./mpas_atmosphere > stdout.log 2> stderr.log

echo
echo "MPAS finished at $(date -Is)"
echo

echo "Generated NetCDF files:"
ls -lh *.nc

echo
echo "Log tail:"
tail -120 log.atmosphere.0000.out || true

echo
echo "Error log:"
cat log.atmosphere.0000.err || true

echo
echo "stderr tail:"
tail -80 stderr.log || true
