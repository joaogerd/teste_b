#!/bin/bash
#PBS -N mpas_smoke_x1.10242
#PBS -q pesqmini
#PBS -l select=1:ncpus=64:mpiprocs=64
#PBS -l walltime=00:20:00
#PBS -j oe

set -euo pipefail

PROJECT_ROOT=/p/projetos/monan_das/joao.gerd/projects/mpas-bmatrix-global
RUN_DIR=/p/projetos/monan_das/joao.gerd/work/mpas-bmatrix-global/runs/smoke_x1.10242_2018041421_6h_np64

source "${PROJECT_ROOT}/scripts/load_jaci_env.sh"

cd "${RUN_DIR}"

export OMP_NUM_THREADS=1
export FI_CXI_RX_MATCH_MODE=hybrid
ulimit -s unlimited || true

echo "Job started at $(date -Is)"
echo "Host: $(hostname)"
echo "PBS_JOBID=${PBS_JOBID:-unknown}"
echo "RUN_DIR=${RUN_DIR}"
echo "PWD=$(pwd)"
echo
echo "Modules:"
module list || true
echo
echo "Executable:"
ls -lh ./mpas_atmosphere
echo
echo "Input:"
ls -lh init.nc x1.10242.invariant.nc x1.10242.graph.info.part.64
echo
echo "Namelist key settings:"
grep -nE "config_start_time|config_run_duration|config_do_restart|config_block_decomp_file_prefix|config_dt|config_physics_suite" namelist.atmosphere || true
echo

echo "Running MPAS..."
mpiexec -n 64 ./mpas_atmosphere > stdout.log 2> stderr.log

echo
echo "MPAS finished at $(date -Is)"
echo
echo "Generated files:"
ls -lh

echo
echo "Last lines of stdout.log:"
tail -80 stdout.log || true

echo
echo "Last lines of stderr.log:"
tail -80 stderr.log || true
